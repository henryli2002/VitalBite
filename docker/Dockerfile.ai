# syntax=docker/dockerfile:1.7
# Build the VitalBite AI worker image with uv for fast, cached installs.

FROM ghcr.io/astral-sh/uv:python3.12-bookworm-slim

ENV UV_LINK_MODE=copy \
    UV_COMPILE_BYTECODE=1 \
    UV_PYTHON_DOWNLOADS=never \
    UV_SYSTEM_PYTHON=1 \
    UV_HTTP_TIMEOUT=600 \
    PIP_NO_CACHE_DIR=1

WORKDIR /app

# 1. Dependency layer — only invalidated when pyproject.toml changes.
COPY pyproject.toml ./
RUN mkdir -p /app/src/langgraph_app /app/src/server \
    && touch /app/src/langgraph_app/__init__.py /app/src/server/__init__.py

RUN --mount=type=cache,id=uv-cache,target=/root/.cache/uv,sharing=shared \
    uv pip install --system \
        --index-strategy unsafe-best-match \
        --extra-index-url https://download.pytorch.org/whl/cpu \
        . "fastapi[all]"

# 2. Application layer.
COPY src/ /app/src/
RUN --mount=type=cache,id=uv-cache,target=/root/.cache/uv,sharing=shared \
    uv pip install --system --no-deps -e .

EXPOSE 8001
CMD ["uvicorn", "server.ai:app", "--host", "0.0.0.0", "--port", "8001", "--workers", "1", "--backlog", "1024", "--timeout-keep-alive", "120"]
