FROM python:3.12-slim

WORKDIR /app/backend

# 1. Cache dependencies (Copy ONLY pyproject.toml)
COPY backend/pyproject.toml .
RUN mkdir -p /app/backend/langgraph_app && touch /app/backend/langgraph_app/__init__.py && \
    pip install --default-timeout=2000 \
    --retries 10 \
    --no-cache-dir \
    --extra-index-url https://download.pytorch.org/whl/cpu \
    . "fastapi[all]"
# 2. Copy the actual application code (Code changes will only invalidate from here down)
COPY backend/langgraph_app/ /app/backend/langgraph_app/
COPY backend/models.py backend/langgraph_server.py /app/backend/

EXPOSE 8001
CMD ["uvicorn", "langgraph_server:app", "--host", "0.0.0.0", "--port", "8001", "--workers", "1", "--backlog", "1024", "--timeout-keep-alive", "120"]
