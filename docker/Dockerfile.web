# syntax=docker/dockerfile:1.7
# Build the VitalBite web image with uv for fast, cached installs.

FROM ghcr.io/astral-sh/uv:python3.12-bookworm-slim

ENV PYTHONUNBUFFERED=1 \
    UV_LINK_MODE=copy \
    UV_COMPILE_BYTECODE=1 \
    UV_PYTHON_DOWNLOADS=never \
    UV_SYSTEM_PYTHON=1 \
    UV_HTTP_TIMEOUT=600 \
    PIP_NO_CACHE_DIR=1

WORKDIR /app

# 1. Dependency layer — only invalidated when pyproject.toml changes.
#    Dummy package roots let uv resolve the local project without the real code.
COPY pyproject.toml ./
RUN mkdir -p /app/src/langgraph_app /app/src/server \
    && touch /app/src/langgraph_app/__init__.py /app/src/server/__init__.py

RUN --mount=type=cache,id=uv-cache,target=/root/.cache/uv,sharing=shared \
    uv pip install --system \
        --index-strategy unsafe-best-match \
        --extra-index-url https://download.pytorch.org/whl/cpu \
        . "fastapi[all]" aiosqlite

# 2. Application layer — reinstalls only the project metadata when src/ changes.
COPY src/ /app/src/
RUN --mount=type=cache,id=uv-cache,target=/root/.cache/uv,sharing=shared \
    uv pip install --system --no-deps -e .

EXPOSE 8000
CMD ["uvicorn", "server.web:app", "--host", "0.0.0.0", "--port", "8000", "--workers", "1", "--backlog", "2048", "--timeout-keep-alive", "120"]
