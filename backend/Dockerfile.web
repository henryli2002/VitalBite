FROM python:3.12-slim

WORKDIR /app/backend

# 1. Cache dependencies (Copy ONLY pyproject.toml)
COPY backend/pyproject.toml .
# Create a dummy folder so pip install doesn't fail trying to build the package
RUN mkdir -p /app/backend/langgraph_app && touch /app/backend/langgraph_app/__init__.py && \
    pip install --no-cache-dir --extra-index-url https://download.pytorch.org/whl/cpu . httpx aiosqlite pydantic "fastapi[all]"

# 2. Copy the actual application code
COPY backend/langgraph_app/ /app/backend/langgraph_app/
COPY frontend/ /app/frontend/
COPY backend/models.py backend/chat_manager.py backend/db.py backend/web_server.py /app/backend/

# In production, data should be mounted as a volume
RUN mkdir -p /app/data

EXPOSE 8000
CMD ["uvicorn", "web_server:app", "--host", "0.0.0.0", "--port", "8000", "--workers", "1", "--backlog", "2048", "--timeout-keep-alive", "120"]
