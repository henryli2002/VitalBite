# Gemini API Configuration
GEMINI_API_KEY=your_api_key_here

# OpenAI API Configuration
OPENAI_API_KEY=your_openai_api_key_here

# AWS Bedrock / Claude Configuration
# 注意：Bedrock 不使用单独的 API Key，而是沿用 AWS 凭证链（环境变量、~/.aws/credentials、IAM 角色等）
# 只需确保 AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY 或 IAM 角色可用
AWS_REGION=ap-southeast-1
BEDROCK_CLAUDE_MODEL_NAME=anthropic.claude-3-haiku-20240307-v1:0
# 可选：本地调试使用的长/短期凭证（生产更推荐 IAM 角色/临时凭证），默认注释以避免误提交
# AWS_ACCESS_KEY_ID=your_access_key_id
# AWS_SECRET_ACCESS_KEY=your_secret_access_key
# AWS_SESSION_TOKEN=your_session_token_if_any

# Model Configuration
# Options: gemini-2.5-flash-lite, gemini-2.0-flash-exp, gemini-1.5-pro, etc.
GEMINI_MODEL_NAME=gemini-2.5-flash-lite
OPENAI_MODEL_NAME=gpt-4o-mini
LLM_PROVIDER=gemini

# LLM default parameters (override as needed)
LLM_DEFAULT_TEMPERATURE=0.3
LLM_DEFAULT_TOP_P=0.9
LLM_DEFAULT_MAX_TOKENS=1024

# Conversation History Configuration
# Number of recent messages to include in context (both user and AI messages)
# Default: 6 (last 3 conversation turns)
HISTORY_MESSAGE_COUNT=6

# Tool Integrations
# Google Maps API Configuration
# Used by the map tool for searching restaurants, locations, and nearby places
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
# Note: IP Location tool (ip-api.com) currently does not require an API key.

