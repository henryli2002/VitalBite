# Gemini API Configuration
GEMINI_API_KEY=your_api_key_here

# OpenAI API Configuration
OPENAI_API_KEY=your_openai_api_key_here

# AWS Bedrock / Claude Configuration
# Ensure AWS credentials are configured via environment or shared config/credentials files
AWS_REGION=ap-southeast-1
BEDROCK_CLAUDE_MODEL_NAME=anthropic.claude-3-5-sonnet-20241022-v2:0

# Model Configuration
# Options: gemini-2.5-flash-lite, gemini-2.0-flash-exp, gemini-1.5-pro, etc.
GEMINI_MODEL_NAME=gemini-2.5-flash-lite
OPENAI_MODEL_NAME=gpt-4o-mini

# Conversation History Configuration
# Number of recent messages to include in context (both user and AI messages)
# Default: 6 (last 3 conversation turns)
HISTORY_MESSAGE_COUNT=6
